# Copy this file to terraform.tfvars and update values for your environment.

aws_region = "us-east-1"
project_name = "purely"
availability_zone = "us-east-1a"

vpc_cidr = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"

# Must be an existing EC2 key pair name in your AWS account/region.
ssh_key_name = "your-keypair-name"

# Use your own AMI ID.
ami_id = "ami-xxxxxxxxxxxxxxxxx"

instance_type = "t3.medium"
root_volume_size = 30

# Restrict SSH to your public IP/CIDR in production.
ssh_ingress_cidr = "0.0.0.0/0"
web_ingress_cidr = "0.0.0.0/0"

kubernetes_api_port = 6443
kubernetes_api_ingress_cidr = "0.0.0.0/0"

argocd_ui_port = 8080
argocd_ingress_cidr = "0.0.0.0/0"
